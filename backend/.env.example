# ===== 大模型（对话生成）=====
# DeepSeek（OpenAI 兼容协议）。Key 建议放系统环境变量，不要提交到仓库。
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ===== Embedding（向量检索）=====
# local = 本地 fastembed（开发期，零 Key）；dashscope = 阿里云 Qwen 云端嵌入（生产推荐）
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIM=512
# 切换到 dashscope 时填写：
DASHSCOPE_API_KEY=
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3
# DashScope 端点：按百炼账号开通地区二选一
#   国内站: https://dashscope.aliyuncs.com/compatible-mode/v1
#   国际站: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ===== 多模态（故障图片理解，M2 使用，需 Qwen-VL）=====
VL_PROVIDER=dashscope
DASHSCOPE_VL_MODEL=qwen-vl-max

# ===== 数据库 =====
# 开发期 SQLite；生产改为 postgresql+psycopg://user:pwd@host:5432/dbname
DATABASE_URL=sqlite:///./app.db

# ===== 鉴权 =====
JWT_SECRET=change-me-in-production-please
JWT_EXPIRE_MINUTES=720

# ===== 检索参数 =====
RETRIEVE_TOP_K=4
