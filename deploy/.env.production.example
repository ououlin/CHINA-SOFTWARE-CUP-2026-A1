# ============================================================
# 生产环境配置模板（LoongArch + 银河麒麟）
# 用法：复制为 backend/.env 并填入真实密钥；切勿提交到仓库（已被 .gitignore 忽略）
# ============================================================

# --- 对话大模型：DeepSeek（OpenAI 兼容协议）---
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=          # ←【必填】填入 DeepSeek Key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- Embedding：服务器端用云端 dashscope，规避 LoongArch 上 onnxruntime 风险 ---
EMBEDDING_PROVIDER=dashscope
DASHSCOPE_API_KEY=         # ←【必填】填入 DashScope/百炼 Key（与 VL 共用）
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1024        # text-embedding-v3 默认 1024 维（JSON 存储时仅作记录）
# 端点按账号开通地区二选一（国际站 Model Studio 账号必须用 -intl，否则 401）：
#   国内站: https://dashscope.aliyuncs.com/compatible-mode/v1
#   国际站: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# --- 多模态（故障图片理解，Qwen-VL）---
VL_PROVIDER=dashscope
DASHSCOPE_VL_MODEL=qwen-vl-max

# --- 数据库：PostgreSQL，纯 Python 驱动 pg8000（零编译）---
# 把 PASSWORD 换成 03_setup_database.sh 中设置的库密码。
DATABASE_URL=postgresql+pg8000://devrepair:CHANGE_ME_DB_PASSWORD@127.0.0.1:5432/devrepair
# 备选：若 PostgreSQL 暂不可用，可临时用 SQLite（纯文件，零依赖）先跑通：
# DATABASE_URL=sqlite:///./app.db

# --- 鉴权：生产务必改成随机长字符串（如 openssl rand -hex 32）---
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET
JWT_EXPIRE_MINUTES=720

# --- 检索参数 ---
RETRIEVE_TOP_K=4
