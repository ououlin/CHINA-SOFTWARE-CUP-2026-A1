# 默认：让 Git 自动判定文本/二进制，并按平台正常处理换行
* text=auto

# 以下文件最终在 Linux/LoongArch 上执行或解析，必须保持 LF 换行，
# 否则 CRLF 会导致 bash 报 "$'\r': command not found"、systemd/nginx 解析异常。
*.sh                            text eol=lf
*.service                       text eol=lf
*.conf                          text eol=lf
deploy/.env.production.example  text eol=lf

# 二进制资源（示例图等）不做换行转换
*.png  binary
*.jpg  binary
*.jpeg binary
*.pdf  binary
